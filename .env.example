# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api
APP_NAME=UrbanShield API

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AWS General
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB
DYNAMODB_ENDPOINT=
DYNAMODB_TABLE_USERS=UrbanShield-Users
DYNAMODB_TABLE_REPORTS=UrbanShield-Reports
DYNAMODB_TABLE_NOTIFICATIONS=UrbanShield-Notifications
DYNAMODB_TABLE_ACTIVITY_LOGS=UrbanShield-ActivityLogs

# Local development (in-memory store when true and no AWS credentials)
USE_IN_MEMORY_STORE=true

# Amazon S3
S3_BUCKET_NAME=urbanshield-uploads
S3_PRESIGNED_URL_EXPIRES_IN=3600
S3_UPLOAD_MAX_SIZE_MB=5

# Amazon Cognito (future integration)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
USE_COGNITO=false

# Amazon SNS
SNS_TOPIC_EMERGENCY_ALERTS=
SNS_TOPIC_ACTIVITY_NOTIFICATIONS=

# Amazon Location Service
LOCATION_MAP_NAME=UrbanShieldMap
LOCATION_PLACE_INDEX=UrbanShieldPlaceIndex

# Password reset (development)
PASSWORD_RESET_TOKEN_EXPIRES_IN=1h
FRONTEND_URL=http://localhost:5173
