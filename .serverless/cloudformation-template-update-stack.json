                {
                  "Effect": "Allow",
                  "Action": [
                    "sns:Publish"
                  ],
                  "Resource": [
                    {
                      "Ref": "EmergencyAlertsTopic"
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "geo:SearchPlaceIndexForText",
                    "geo:GetMapTile"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ],
        "Path": "/",
        "RoleName": {
          "Fn::Join": [
            "-",
            [
              "urbanshield-backend",
              "dev",
              {
                "Ref": "AWS::Region"
              },
              "lambdaRole"
