            "COGNITO_CLIENT_ID": "5mscvi0k161ouut5ph5g4jnm4v",
            "SNS_TOPIC_EMERGENCY_ALERTS": {
              "Ref": "EmergencyAlertsTopic"
            },
            "LOCATION_MAP_NAME": "UrbanShieldMap",
            "LOCATION_PLACE_INDEX": "UrbanShieldPlaceIndex"
