                  "Resource": [
                    {
                      "Fn::GetAtt": [
                        "UsersTable",
                        "Arn"
                      ]
                    },
                    {
                      "Fn::Sub": "${UsersTable.Arn}/index/GSI_Email"
                    },
                    {
                      "Fn::GetAtt": [
                        "ReportsTable",
                        "Arn"
                      ]
                    },
                    {
                      "Fn::GetAtt": [
                        "NotificationsTable",
                        "Arn"
                      ]
                    },
                    {
                      "Fn::GetAtt": [
                        "ActivityLogsTable",
                        "Arn"
                      ]
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:PutObject",
                    "s3:GetObject",
                    "s3:DeleteObject"
                  ],
                  "Resource": [
                    {
                      "Fn::Sub": "arn:aws:s3:::urbanshield-uploads-dev-130063747200/*"
